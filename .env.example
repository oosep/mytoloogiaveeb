# === Mütoloogiaveeb keskkonnamuutujad ===
# Kopeeri see fail nimega .env ja täida väärtused. .env EI lähe kunagi GitHubi!

# JWT allkirjastamise saladus — vähemalt 32 juhuslikku tähemärki.
# Genereeri nt: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Mapboxi avalik token (pk....). Piira Mapboxi paneelis URL-iga (URL restrictions).
MAPBOX_TOKEN=

# Lubatud päritolud muutvatele päringutele (CSRF kaitse), komaga eraldatud.
# Nt: https://mytoloogiaveeb.up.railway.app
LUBATUD_ORIGINID=

# Cloudflare Turnstile (CAPTCHA) võtmed — https://dash.cloudflare.com -> Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Keskkond — sea 'production' Railwayl. Tootmises jõustuvad rangemad kontrollid.
NODE_ENV=production

# Esmase admin-kasutaja parool TOOTMISES (min 12 märki). Testkasutajaid
# (admin/admin123 jne) tootmises EI looda — ainult see konto.
ADMIN_PAROOL=
ADMIN_EMAIL=

# Üleslaaditud failide krüpteerimisvõti kettal (AES-256-GCM) — täpselt 64 hex märki.
# Genereeri: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Kui tühi, salvestatakse failid krüpteerimata (arenduses OK).
MANUSTE_VOTI=

# Üleslaaditud failide kaust (vaikimisi ./uploads). Railwayl suuna püsikettale (volume).
MANUSTE_KAUST=